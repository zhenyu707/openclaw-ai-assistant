# OpenClaw HR Agent — Environment Variables Template
#
# Copy this file: cp .env.template .env
# Fill in all values, then source it: source ~/.openclaw/.env
# Or add the exports to your ~/.bashrc / ~/.zshrc
#
# NEVER commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
export ANTHROPIC_API_KEY="sk-ant-..."

# ── OpenClaw Gateway ───────────────────────────────────────────────────────
# Must match the token in openclaw.json → gateway.auth.token
export OPENCLAW_GATEWAY_TOKEN="YOUR_LONG_RANDOM_GATEWAY_TOKEN"

# Must match openclaw.json → hooks.token
export OPENCLAW_WEBHOOK_SECRET="YOUR_WEBHOOK_SECRET_TOKEN"

# ── HRIS Integration ───────────────────────────────────────────────────────
export HRIS_API_URL="https://hris.yourcompany.com/api/v1"
export HRIS_API_KEY="your-hris-api-key-here"

# ── Slack ──────────────────────────────────────────────────────────────────
# Incoming webhook URL for #hr-weekly and HR announcements
export SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# ── Email ──────────────────────────────────────────────────────────────────
export HR_MANAGER_EMAIL="hrmanager@yourcompany.com"
export HR_GENERAL_EMAIL="hr@yourcompany.com"
export FINANCE_EMAIL="finance@yourcompany.com"

# ── IT Provisioning (optional) ─────────────────────────────────────────────
# Webhook endpoint for triggering IT provisioning on new hire
export IT_PROVISIONING_WEBHOOK_URL="https://it.yourcompany.com/webhooks/onboarding"
export IT_PROVISIONING_TOKEN="your-it-webhook-token"

# ── Calendar (optional) ────────────────────────────────────────────────────
# Google Calendar service account or MS Graph credentials
# export GOOGLE_CALENDAR_CREDENTIALS_PATH="~/.openclaw/google-creds.json"
# export MS_GRAPH_TENANT_ID=""
# export MS_GRAPH_CLIENT_ID=""
# export MS_GRAPH_CLIENT_SECRET=""
